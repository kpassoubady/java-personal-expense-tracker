<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="ExpenseTrackerSmokeTestSuite" parallel="classes" thread-count="1" verbose="1">
    
    <parameter name="browser" value="chrome"/>
    <parameter name="headless" value="false"/>
    <parameter name="environment" value="local"/>
    
    <!-- Listeners for test reporting and screenshots -->
    <listeners>
        <listener class-name="com.expensetracker.app.e2e.listeners.ExtentReportListener"/>
        <listener class-name="com.expensetracker.app.e2e.listeners.ScreenshotOnFailureListener"/>
        <listener class-name="com.expensetracker.app.e2e.listeners.TestExecutionTimeLogger"/>
        <!-- <listener class-name="com.expensetracker.app.e2e.listeners.RetryAnalyzer"/> -->
        <listener class-name="com.expensetracker.app.e2e.reporting.ComprehensiveReportingListener"/>
    </listeners>
    
    <!-- Smoke Tests - Critical functionality only -->
    <test name="SmokeTests" enabled="true">
        <parameter name="testType" value="smoke"/>
        <classes>
            <class name="com.expensetracker.app.e2e.tests.smoke.SmokeTests"/>
        </classes>
    </test>
    
</suite>